   COCO_CI: "1"
 
 jobs:
+  # infra-015: lint pre-job。把 phase-12 落地的 lint_paths_filter.py /
+  # lint_workflows.py（actionlint dry-run hook）真接入 CI。
+  # - actionlint binary 通过 rhysd 官方 download-actionlint.bash 安装
+  #   （v1.7.12 pin tag），PATH 注入走 $GITHUB_PATH 而非 /usr/local/bin/
+  # - lint_paths_filter.py 校验 .github/paths-filter.yml schema / 兜底
+  # - lint_workflows.py --strict 对所有 .github/workflows/*.yml 跑 actionlint
+  # 后续 verify-* matrix job 走 needs: [smoke, changes, lint]，lint 红即整个
+  # matrix fail-fast，避免 workflow 自身坏掉时再消耗 CI 跑业务 verify。
+  # round 2 fix: 不再用 rhysd/actionlint@v1（该仓库无 action.yml），改走
+  # 官方 download-actionlint.bash + GITHUB_PATH 注入（C1/C3 修复）。
+  lint:
+    name: lint workflows + paths-filter (infra-015)
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: "3.13"
+      - name: Install actionlint (pinned 1.7.12 via rhysd download script)
+        id: actionlint
+        run: |
+          set -euo pipefail
+          # rhysd/actionlint 官方推荐安装方式；脚本会下到当前目录
+          bash <(curl -sSL https://raw.githubusercontent.com/rhysd/actionlint/v1.7.12/scripts/download-actionlint.bash) 1.7.12
+          pwd >> "$GITHUB_PATH"
+      - name: Show actionlint version
+        run: actionlint -version
+      - name: Lint paths-filter (infra-011/013/015)
+        run: python scripts/lint_paths_filter.py
+      - name: Lint workflows (actionlint --strict, infra-015)
+        run: python scripts/lint_workflows.py --strict
+
   # infra-011: paths-filter gate。
